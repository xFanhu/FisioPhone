<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FisioPhone" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/azul</item>
        <item name="colorPrimaryVariant">@color/Borde</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/icon_tint</item>
        <item name="colorSecondaryVariant">@color/icon_tint</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@drawable/background</item>
        <item name="android:navigationBarColor">?android:attr/colorBackground</item>
    </style>

    <style name="Theme.InicioFisioPhone" parent="Theme.FisioPhone">
        <item name="android:windowBackground">@drawable/iniciobackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>
</resources>
