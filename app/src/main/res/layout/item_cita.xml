<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_input"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvCitaTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/azul"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="10:00" />

            <TextView
                android:id="@+id/tvCitaDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/description_gray"
                android:textSize="10sp"
                tools:text="25 Abr" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCitaNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/description_gray"
                android:textSize="12sp"
                tools:text="Fisioterapeuta:" />

            <TextView
                android:id="@+id/tvCitaNameValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/card_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Marta Ruiz" />

            <TextView
                android:id="@+id/tvCitaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_input"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Confirmada"
                android:textColor="@color/azul"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivDeleteCita"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_delete"
            app:tint="#FF5252" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
