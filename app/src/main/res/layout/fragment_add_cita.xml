<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvAddCitaTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/anton"
            android:text="@string/nueva_cita"
            android:textColor="@color/card_text"
            android:textSize="28sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Step 1: Select Physio -->
        <TextView
            android:id="@+id/tvSelectPhysioLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/seleccionar_fisioterapeuta"
            android:textColor="@color/card_text"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAddCitaTitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhysioSelector"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvSelectPhysioLabel">

            <AutoCompleteTextView
                android:id="@+id/autoCompletePhysio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/seleccionar_profesional"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Step 2: Select Treatment -->
        <TextView
            android:id="@+id/tvSelectTreatmentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/seleccionar_tratamiento"
            android:textColor="@color/card_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilPhysioSelector"
            tools:visibility="visible" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgTreatments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvSelectTreatmentLabel"
            app:singleSelection="true"
            tools:visibility="visible" />

        <!-- Step 3: Select Date -->
        <TextView
            android:id="@+id/tvSelectDateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/elegir_dia"
            android:textColor="@color/card_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cgTreatments"
            tools:visibility="visible" />

        <Button
            android:id="@+id/btnOpenCalendar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/abrir_calendario"
            android:visibility="gone"
            app:icon="@drawable/ic_calendar"
            app:layout_constraintTop_toBottomOf="@id/tvSelectDateLabel"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvSelectedDateDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/azul"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnOpenCalendar"
            tools:text="Día seleccionado: 25/04/2026"
            tools:visibility="visible" />

        <!-- Step 3: Select Time Slot -->
        <TextView
            android:id="@+id/tvSelectTimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/horas_disponibles"
            android:textColor="@color/card_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSelectedDateDisplay"
            tools:visibility="visible" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgTimeSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvSelectTimeLabel"
            app:singleSelection="true" />

        <!-- Step 4: Confirm -->
        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/azul"
            android:text="@string/confirmar_reserva"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cgTimeSlots"
            tools:visibility="visible" />

        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
