<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="64dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    tools:context=".ui.menu.fragments.ProfileFragment">

    <TextView
        android:id="@+id/tvProfileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/perfil"
        android:textColor="@color/card_text"
        android:textSize="28sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/photoPickerCard"
                            android:layout_width="104dp"
                            android:layout_height="104dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/card_background"
                            app:cardCornerRadius="52dp"
                            app:cardElevation="4dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <ImageView
                                    android:id="@+id/ivProfilePhoto"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/perfil_foto"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_profile"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvProfilePhotoPlaceholder"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_profile_photo_placeholder"
                                    android:fontFamily="@font/anton"
                                    android:gravity="center"
                                    android:padding="12dp"
                                    android:text="@string/perfil_anadir_foto"
                                    android:textAlignment="center"
                                    android:textColor="@color/card_text"
                                    android:textSize="14sp" />

                            </FrameLayout>

                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNameLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/perfil_nombre"
                                android:textColor="@color/card_text"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvNameValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/card_text"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="Lucia" />

                            <TextView
                                android:id="@+id/tvApellidosLabel"
                                android:layout_marginTop="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/perfil_apellidos"
                                android:textColor="@color/card_text"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvApellidosValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/card_text"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="Fernandez Lopez" />
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEmailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/email"
                        android:textColor="@color/card_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvEmailValue"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/card_text"
                        android:textSize="15sp"
                        tools:text="lucia.fernandez@email.com" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvSessionsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/anton"
                android:text="@string/perfil_historial_sesiones"
                android:textColor="@color/card_text"
                android:textSize="22sp" />

            <LinearLayout
                android:id="@+id/sessionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvSessionsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/perfil_sesiones_vacias"
                android:textColor="@color/description_gray"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
